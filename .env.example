# Copy to .env (never committed) and fill in. Treat values as live credentials.
# AgDR-0001: Red Team uses Anthropic Sonnet instead of Fireworks Dolphin until a Fireworks key lands.

# --- LLM providers ---
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_REDTEAM=          # Optional. If unset, falls back to ANTHROPIC_API_KEY (single-key warning logged).
ANTHROPIC_API_KEY_JUDGE=            # Optional. If unset, falls back to ANTHROPIC_API_KEY.
ANTHROPIC_ORCHESTRATOR_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-6
ANTHROPIC_FAST_FALLBACK_MODEL=claude-haiku-4-5

# Red Team provider switch — AgDR-0001 documents the substitution.
REDTEAM_PROVIDER=anthropic          # anthropic | fireworks
REDTEAM_MODEL=claude-sonnet-4-6     # Used when REDTEAM_PROVIDER=anthropic.

# Fireworks — populate to switch Red Team to Dolphin.
FIREWORKS_API_KEY=
FIREWORKS_REDTEAM_MODEL=accounts/fireworks/models/dolphin-2-9-2-qwen2-72b
FIREWORKS_REDTEAM_FALLBACK_MODEL=accounts/fireworks/models/nous-hermes-3-llama-3-1-70b

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- Persistence ---
PLATFORM_DB_URL=sqlite:///./data/agentforge.sqlite

# --- HMAC + adapter safety ---
AGENT_MESSAGE_SIGNING_SECRET=        # 32+ random bytes. Generate with `python -c "import secrets; print(secrets.token_hex(32))"`.
TARGET_ALLOWLIST=localhost,127.0.0.1,host.docker.internal

# --- Target (Co-Pilot) ---
TARGET_BASE_URL=http://localhost:8300
TARGET_HTTPS_BASE_URL=https://localhost:9300
COPILOT_SIDECAR_URL=http://localhost:8000
COPILOT_GATEWAY_PATH=/interface/modules/custom_modules/oe-module-clinical-copilot
OPENEMR_ADMIN_USER=admin
OPENEMR_ADMIN_PASS=pass
SIDECAR_SHARED_SECRET=               # If sidecar requires it; otherwise blank.

# --- Budget guard ---
BUDGET_SMOKE_USD=1.00
BUDGET_SEEDED_USD=5.00
BUDGET_EXPLORATORY_USD=10.00
BUDGET_PER_DAY_USD=25.00
BUDGET_HALT_AFTER_N_NULL_RUNS=25
BUDGET_NULL_RUN_SPEND_THRESHOLD_USD=3.00
BUDGET_PER_ATTACK_TIMEOUT_S=60
BUDGET_TARGET_ERROR_RATE_HALT=0.20

# --- Capability flags ---
ALLOW_BROWSER_AUTOMATION=false       # Playwright opt-in. Off by default.
ALLOW_TARGET_FIXES_PUSH=false        # Documentation Agent must NEVER push without this flag + AgDR.

# --- Freshness ---
PRICING_YML_FRESHNESS_DAYS=30
